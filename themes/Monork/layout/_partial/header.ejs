<header id="header">
    <div id="banner"></div>
    <<% if (theme.shade_bg && (theme.shade_bg_precente == 70 || theme.shade_bg_precente == 40 || theme.shade_bg_precente == 20 || theme.shade_bg_precente == 0)){ %>
        <div id="shade-bg"></div>
    <%} else { %>
        <div id="shade-bg-default"></div>
    <% } %>
    <div id="header-outer" class="outer">
        <div id="header-title" class="inner">
            <h1 id="logo-wrap">
                <% if (theme.title) {%>
                <a href="javascript:void(0)" id="logo"><%= theme.title %></a>
                <%} else { %>
                <a href="javascript:void(0)" id="logo"><%= config.title %></a>
                <% } %>
            </h1>
            <h2 id="subtitle-wrap">
                <% if (theme.subtitle){ %>
                <a href="javascript:void(0)" id="subtitle"><%= theme.subtitle %></a>
                <%} else { %>
                <a href="javascript:void(0)" id="logo"><%= config.subtitle %></a>
                <% } %>
            </h2>
        </div>
        <div id="header-inner" class="inner">
            <nav id="main-nav">
                <a id="main-nav-toggle" class="nav-icon"></a>
                <% for (var i in theme.menu){ %>
                <a class="main-nav-link" href="<%- url_for(theme.menu[i]) %>"><%= i %></a>
                <% } %>
            </nav>
            <nav id="sub-nav">
                <a id="nav-search-btn" class="nav-icon" title="<%= __('search') %>">
                    <div id="search-form-wrap">
                        <%- search_form({button: '&#xF002;'}) %>
                    </div>
                </a>
                <% if (theme.rss){ %>
                <a id="nav-rss-link" class="nav-icon" href="<%- theme.rss %>" title="<%= __('rss_feed') %>"></a>
                <% } %>
            </nav>
        </div>
    </div>
</header>